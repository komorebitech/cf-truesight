{
  "family": "truesight-ch-writer",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::581933458044:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::581933458044:role/truesight-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "truesight-ch-writer",
      "image": "581933458044.dkr.ecr.ap-south-1.amazonaws.com/truesight/ch-writer:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 9090,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "CH_BATCH_SIZE", "value": "1000" },
        { "name": "CH_FLUSH_INTERVAL_SECS", "value": "5" },
        { "name": "SQS_RECEIVE_BATCH_SIZE", "value": "10" },
        { "name": "AWS_REGION", "value": "ap-south-1" },
        { "name": "CLICKHOUSE_DATABASE", "value": "truesight" },
        { "name": "CLICKHOUSE_USER", "value": "default" },
        { "name": "RUST_LOG", "value": "info,truesight=debug" }
      ],
      "secrets": [
        {
          "name": "SQS_QUEUE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:581933458044:secret:truesight/sqs-queue-url"
        },
        {
          "name": "CLICKHOUSE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:581933458044:secret:truesight/clickhouse-url"
        },
        {
          "name": "CLICKHOUSE_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:581933458044:secret:truesight/clickhouse-password"
        },
        {
          "name": "SENTRY_DSN",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:581933458044:secret:truesight/sentry-dsn"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/truesight-ch-writer",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:9090/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
